# ── Lehrerkalender Server-Konfiguration ─────────────────────────────
# Diese Datei nach ".env" kopieren und Werte ausfüllen. .env NIE committen.

# Port des Servers
PORT=3000

# Verzeichnis für die verschlüsselten Pro-Nutzer-Datenbanken
DATA_DIR=./data

# Master-Schlüssel für die Verschlüsselung (32 Byte, base64).
# Erzeugen z. B. mit:  openssl rand -base64 32
# WICHTIG: geheim halten und sichern – ohne diesen Schlüssel sind ALLE DBs unlesbar.
MASTER_KEY=

# Geheimnis für Session-Cookies. Erzeugen z. B. mit:  openssl rand -base64 32
SESSION_SECRET=

# In Produktion (hinter HTTPS-Reverse-Proxy) auf "true" setzen -> secure-Cookies
SECURE_COOKIES=false

# Fremde Herkünfte, die die App per <iframe> einbetten dürfen (z. B. Nextcloud
# "Externe Seiten"). Kommagetrennte Origins OHNE Pfad/Slash. Leer = kein Embedding.
# Wenn gesetzt: Session-Cookie wird SameSite=None;Secure (braucht SECURE_COOKIES=true
# und HTTPS) und frame-ancestors/X-Frame-Options werden für diese Herkünfte geöffnet.
# Hinweis: funktioniert nur, solange der Browser Dritt-Cookies erlaubt
# (Chrome/Edge/Firefox aktuell ok; Safari blockt sie). Robuster: App unter eine
# Subdomain DERSELBEN Basisdomain wie die einbettende Seite legen (dann same-site).
# Beispiel:
# EMBED_ANCESTORS=https://cloud.schule.de
EMBED_ANCESTORS=

# SameSite-Strategie fürs Session-Cookie beim Embedding (nur wirksam mit EMBED_ANCESTORS):
#   none = cross-site-Embedding (App und einbettende Seite auf VERSCHIEDENEN
#          Basisdomains). Hängt an Dritt-Cookies -> Safari blockt. Default.
#   lax  = same-site-Embedding (beide auf DERSELBEN Basisdomain, z. B.
#          cloud.schule.de + kalender.schule.de). Funktioniert in ALLEN Browsern
#          inkl. Safari und ist CSRF-sicherer -> nach Umzug auf gemeinsame Domain setzen.
EMBED_SAMESITE=none

# ── Authentifizierung ───────────────────────────────────────────────
# AUTH_MODE=dev   -> einfacher Test-Login (jeder Username, kein Passwort-Check)
# AUTH_MODE=ldap  -> echtes LDAP (Felder unten ausfüllen)
AUTH_MODE=dev

# Optional: Komma-getrennte Allowlist erlaubter Dev-Usernamen (leer = alle erlaubt)
DEV_ALLOWED_USERS=

# ── LDAP / Active Directory (nur bei AUTH_MODE=ldap) ────────────────
# {{username}} wird jeweils durch die eingegebene Anmeldekennung ersetzt.
LDAP_URL=ldaps://dc01.schule.local:636
LDAP_BASE_DN=DC=schule,DC=local
# Suchfilter für den Nutzer (AD-Standard: sAMAccountName).
LDAP_USER_FILTER=(sAMAccountName={{username}})

# --- Variante A: Direkt-Bind (empfohlen, kein Service-Account nötig) ---
# Der Nutzer bindet direkt mit eigener Kennung + Passwort. NetBIOS-Form
# (z. B. SNRD\{{username}}) oder UPN ({{username}}@snrd.local).
LDAP_BIND_USER_TEMPLATE=SNRD\{{username}}

# --- Variante B: Service-Account (nur falls KEIN Direkt-Bind genutzt wird) ---
# Bei gesetztem LDAP_BIND_USER_TEMPLATE werden diese beiden ignoriert.
LDAP_BIND_DN=CN=svc-lehrerkalender,OU=ServiceAccounts,DC=schule,DC=local
LDAP_BIND_PW=
# Attribut für die stabile Login-Kennung bzw. den Anzeigenamen.
LDAP_LOGIN_ATTR=sAMAccountName
LDAP_NAME_ATTR=displayName

# --- TLS für ldaps:// ---
# Bei interner CA den Pfad zur CA-PEM angeben (empfohlen):
# LDAP_TLS_CA_PFAD=/pfad/zur/internen-ca.pem
# Notlösung (nur in vertrauenswürdigen Netzen): Zertifikatsprüfung abschalten:
# LDAP_TLS_REJECT_UNAUTHORIZED=false
